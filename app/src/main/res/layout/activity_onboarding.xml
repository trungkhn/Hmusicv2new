<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"> <androidx.viewpager2.widget.ViewPager2
    android:id="@+id/viewPager"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_above="@+id/btnGetStarted"
    android:layout_marginBottom="24dp"/> <androidx.cardview.widget.CardView
    android:id="@+id/btnGetStarted"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    app:cardCornerRadius="28dp"
    app:cardBackgroundColor="@color/apple_pink"
    app:cardElevation="6dp"
    android:outlineAmbientShadowColor="#FF2D55"
    android:outlineSpotShadowColor="#FF2D55"
    android:layout_alignParentBottom="true"
    android:layout_marginHorizontal="32dp"
    android:layout_marginBottom="48dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bắt đầu ngay"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:fontFamily="sans-serif-bold"
        android:layout_gravity="center"/>
</androidx.cardview.widget.CardView>

</RelativeLayout>