<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp"
    android:background="?attr/selectableItemBackground">

    <androidx.cardview.widget.CardView
        android:layout_width="64dp"
        android:layout_height="64dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#E5E5EA">

        <ImageView
            android:id="@+id/ivLibPlaylistCover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery"
            app:tint="#8E8E93"/> </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="16dp">

        <TextView
            android:id="@+id/tvLibPlaylistName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tên Playlist"
            android:textColor="#1D1D1F"
            android:textSize="18sp"
            android:fontFamily="sans-serif-bold"
            android:singleLine="true"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tvLibSongCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 bài hát"
            android:textColor="#8E8E93"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    </LinearLayout>