<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:paddingHorizontal="40dp"
    android:background="@android:color/transparent">

    <androidx.cardview.widget.CardView
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_marginBottom="48dp"
        app:cardBackgroundColor="#F5F5F7"
        app:cardCornerRadius="48dp"
        app:cardElevation="0dp">

        <ImageView
            android:id="@+id/imgOnboarding"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="24dp"
            android:src="@android:drawable/sym_def_app_icon"
            android:scaleType="centerInside" />

    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="Tiêu đề giới thiệu"
        android:textColor="#1D1D1F"
        android:textSize="34sp"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="-0.03"
        android:textAlignment="center" />

    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Khám phá không gian âm nhạc tuyệt đỉnh. Vuốt để cảm nhận sự mượt mà và tận hưởng từng giai điệu!"
        android:textColor="#8E8E93"
        android:textSize="17sp"
        android:fontFamily="sans-serif-medium"
        android:lineSpacingExtra="8dp"
        android:textAlignment="center"/>

</LinearLayout>