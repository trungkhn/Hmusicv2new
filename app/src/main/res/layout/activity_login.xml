<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Top bar với nút Back -->
    <RelativeLayout
        android:id="@+id/topBarLogin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:paddingHorizontal="24dp"
        android:paddingBottom="16dp">

        <ImageView
            android:id="@+id/btnBackLogin"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#1D1D1F"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"/>
    </RelativeLayout>

    <!-- Nội dung chính ở giữa màn hình -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="32dp">

        <!-- Logo app -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@mipmap/hmusicv2"

            android:layout_marginBottom="16dp"/>

        <!-- Tên app -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hmusic"
            android:textColor="#1D1D1F"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginBottom="48dp"/>

        <!-- Email -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="56dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F2F2F7"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/edtEmail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="Email"
                android:textColorHint="#8E8E93"
                android:textColor="#1D1D1F"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="20dp"
                android:inputType="textEmailAddress"/>
        </androidx.cardview.widget.CardView>

        <!-- Password -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="56dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F2F2F7"
            android:layout_marginBottom="32dp">

            <EditText
                android:id="@+id/edtPassword"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="Mật khẩu"
                android:textColorHint="#8E8E93"
                android:textColor="#1D1D1F"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="20dp"
                android:inputType="textPassword"/>
        </androidx.cardview.widget.CardView>

        <!-- Nút Đăng nhập -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            app:cardCornerRadius="28dp"
            app:cardBackgroundColor="@color/apple_pink"
            app:cardElevation="6dp"
            android:outlineAmbientShadowColor="#FF2D55"
            android:outlineSpotShadowColor="#FF2D55"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đăng nhập"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:fontFamily="sans-serif-bold"
                android:layout_gravity="center"/>
        </androidx.cardview.widget.CardView>

        <!-- Chuyển sang Đăng ký -->
        <LinearLayout
            android:id="@+id/tvToRegister"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="32dp"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chưa có tài khoản? "
                android:textColor="#8E8E93"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đăng ký ngay"
                android:textColor="@color/apple_pink"
                android:textSize="15sp"
                android:fontFamily="sans-serif-bold"/>
        </LinearLayout>

    </LinearLayout>
</RelativeLayout>