<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <RelativeLayout
        android:id="@+id/topBarRegister"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:paddingHorizontal="24dp"
        android:paddingBottom="16dp">

        <ImageView
            android:id="@+id/btnBackRegister"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@mipmap/hmusicv2"

            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"/>
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="32dp">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@android:drawable/sym_def_app_icon"
            app:tint="@color/apple_pink"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign up"
            android:textColor="#1D1D1F"
            android:textSize="36sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.02"
            android:layout_marginBottom="40dp"/>
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="56dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F2F2F7"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/edtName"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="Full Name"
                android:textColorHint="#8E8E93"
                android:textColor="#1D1D1F"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="20dp"
                android:inputType="textPersonName"/>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="56dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F2F2F7"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/edtEmail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="Email"
                android:textColorHint="#8E8E93"
                android:textColor="#1D1D1F"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="20dp"
                android:inputType="textEmailAddress"/>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="56dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F2F2F7"
            android:layout_marginBottom="32dp">

            <EditText
                android:id="@+id/edtPassword"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="Password"
                android:textColorHint="#8E8E93"
                android:textColor="#1D1D1F"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="20dp"
                android:inputType="textPassword"/>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            app:cardCornerRadius="28dp"
            app:cardBackgroundColor="@color/apple_pink"
            app:cardElevation="6dp"
            android:outlineAmbientShadowColor="#FF2D55"
            android:outlineSpotShadowColor="#FF2D55"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đăng ký"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:fontFamily="sans-serif-bold"
                android:layout_gravity="center"/>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:id="@+id/tvToLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="32dp"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account? "
                android:textColor="#8E8E93"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Log in"
                android:textColor="@color/apple_pink"
                android:textSize="15sp"
                android:fontFamily="sans-serif-bold"/>
        </LinearLayout>

    </LinearLayout>
</RelativeLayout>